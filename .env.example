# Conversa — Audio-First Environment Example
# Copy to `.env` and fill as needed. This release has NO video-related variables.
# MVP uses BYOK (user-supplied OpenAI key in the UI); no server-side secrets required.

# --- Audio ingestion validation (configurable) ---
# Max audio file size in bytes (default 10 MB)
AUDIO_MAX_BYTES=10485760

# Max audio duration in seconds (default 2 hours)
AUDIO_MAX_SECONDS=7200

# Allowed audio MIME types (comma-separated). M4A uses audio/mp4 (audio container, NOT video/mp4).
AUDIO_ALLOWED_MIME_TYPES=audio/mpeg,audio/wav,audio/mp4

# --- Feature flags ---
# Video is a documented future capability, disabled by default. Do not enable in this release.
MEDIA_VIDEO_ENABLED=false

# --- Transcription provider (interface: AudioTranscriptionProvider.transcribe) ---
# openai | wispr | local  (provider selection; BYOK key supplied by user at runtime in MVP)
TRANSCRIPTION_PROVIDER=openai

# --- Storage (opaque, tenant/workspace-scoped references; raw audio never in logs) ---
# Object storage bucket/prefix base; platform scopes by tenantId/workspaceId.
AUDIO_STORAGE_PREFIX=media

# Retention in days for audio assets (configurable per tenant).
AUDIO_RETENTION_DAYS=90
